# Application
APP_NAME=GrantMatch
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# Database (matches docker-compose db service)
DATABASE_URL=postgresql+psycopg://grantmatch:grantmatch@localhost:5432/grantmatch

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

